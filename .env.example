# ══════════════════════════════════════════════
#  Variables requeridas para despliegue en Vercel
#  Configura estas en: Vercel → Project → Settings → Environment Variables
# ══════════════════════════════════════════════

# Base de datos PostgreSQL (REQUERIDA)
# Proveedores compatibles: Neon, Supabase, Vercel Postgres, Railway
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Secreto para firmar cookies de sesion (REQUERIDO)
# Genera uno con: openssl rand -base64 32
SESSION_SECRET=cambia_este_secreto_por_uno_seguro

# Nombre visible de la aplicacion
PUBLIC_APP_NAME=Technological Cameras
PUBLIC_APP_VERSION=1.0.0

# Ruta de backups (solo entorno local)
BACKUP_PATH=./backups