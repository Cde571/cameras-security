---
// src/pages/index.astro
// Dashboard principal del sistema de cotizaciones

import MainLayout from "../layouts/MainLayout.astro";

// Importar componentes React SIN extensión (.tsx)
import KPICard from "../components/dashboard/KPICard";
import QuickActions from "../components/dashboard/QuickActions";
import RecentDocuments from "../components/dashboard/RecentDocuments";
import AlertsList from "../components/dashboard/AlertsList";

// TODO: Reemplazar con datos reales de la base de datos
const dashboardData = {
  kpis: {
    totalCotizadoMes: 45_680_000,
    cotizacionesPendientes: 8,
    ordenesEnCurso: 3,
    carteraVencida: 2_340_000,
  },
  recentDocs: [
    {
      id: 1,
      type: "cotizacion",
      number: "COT-2026-045",
      client: "Hotel Plaza Real",
      amount: 3_594_300,
      date: "2026-01-18",
      status: "enviada",
    },
    {
      id: 2,
      type: "cobro",
      number: "CC-2026-089",
      client: "Supermercado El Ahorro",
      amount: 2_150_000,
      date: "2026-01-17",
      status: "pendiente",
    },
    {
      id: 3,
      type: "orden",
      number: "OT-2026-123",
      client: "Clínica San Rafael",
      amount: 8_900_000,
      date: "2026-01-16",
      status: "en_progreso",
    },
  ],
  alerts: [
    {
      id: 1,
      type: "warning",
      message: "Cotización COT-2026-032 vence mañana",
      action: "/cotizaciones/32",
    },
    {
      id: 2,
      type: "danger",
      message: "2 cuentas de cobro vencidas",
      action: "/pagos/cartera",
    },
    {
      id: 3,
      type: "info",
      message: "Orden OT-2026-118 lista para acta de entrega",
      action: "/ordenes/118",
    },
  ],
};

// Metadata de la página
const pageTitle = "Dashboard - Sistema de Cotizaciones";
const pageDescription =
  "Panel principal del sistema de gestión de cotizaciones y ventas";

const todayLong = new Date().toLocaleDateString("es-CO", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
});

const currentMonth = new Date().toLocaleDateString("es-CO", { month: "long" });
---

<MainLayout title={pageTitle} description={pageDescription}>
  <!-- Hero / Welcome Section -->
  <section class="bg-gradient-to-r from-blue-600 to-blue-700 rounded-xl shadow-lg p-8 mb-8">
    <div class="flex items-center justify-between gap-6">
      <div class="text-white">
        <h1 class="text-3xl font-bold mb-2">Bienvenido de nuevo</h1>
        <p class="text-blue-100 text-lg">Hoy es {todayLong}</p>
      </div>

      <div class="hidden md:block">
        <div class="bg-white/20 backdrop-blur-sm rounded-lg p-4 text-white text-center">
          <p class="text-sm text-blue-100 mb-1">Mes actual</p>
          <p class="text-3xl font-bold">{currentMonth}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- KPIs Grid -->
  <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <KPICard
      client:load
      title="Cotizado este mes"
      value={dashboardData.kpis.totalCotizadoMes}
      type="currency"
      icon="dollar-sign"
      trend={{ value: 13, direction: "up" }}
      color="blue"
    />

    <KPICard
      client:load
      title="Cotizaciones pendientes"
      value={dashboardData.kpis.cotizacionesPendientes}
      type="number"
      icon="file-text"
      color="orange"
      link="/cotizaciones?status=pendiente"
    />

    <KPICard
      client:load
      title="Órdenes en curso"
      value={dashboardData.kpis.ordenesEnCurso}
      type="number"
      icon="wrench"
      color="green"
      link="/ordenes?status=en_progreso"
    />

    <KPICard
      client:load
      title="Cartera vencida"
      value={dashboardData.kpis.carteraVencida}
      type="currency"
      icon="alert-circle"
      trend={{ value: 5, direction: "down" }}
      color="red"
      link="/pagos/cartera?filter=vencida"
    />
  </section>

  <!-- Acciones rápidas y Alertas -->
  <section class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2">
      <QuickActions client:load />
    </div>

    <div>
      <AlertsList client:load alerts={dashboardData.alerts} />
    </div>
  </section>

  <!-- Documentos Recientes -->
  <section class="bg-white rounded-xl shadow-md border border-gray-200">
    <div class="border-b border-gray-200 px-6 py-4">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-xl font-bold text-gray-800">Documentos recientes</h2>

        <a
          href="/cotizaciones"
          class="text-blue-600 hover:text-blue-700 text-sm font-medium flex items-center gap-1 transition-colors"
        >
          Ver todos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"
            />
          </svg>
        </a>
      </div>
    </div>

    <RecentDocuments client:load documents={dashboardData.recentDocs} />
  </section>

  <!-- Footer Info -->
  <footer class="mt-8 text-center text-sm text-gray-500">
    <p>
      Sistema de Cotizaciones v1.0
      <span class="mx-2">•</span>
      Última actualización: {new Date().toLocaleTimeString("es-CO")}
    </p>
  </footer>
</MainLayout>

<style>
  /* Animación de entrada suave (opcional) */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fadeIn {
    animation: fadeInUp 0.5s ease-out;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const alertas = document.querySelectorAll('[data-alert-type="danger"]');
    if (alertas.length > 0) {
      console.log(`Tienes ${alertas.length} alertas importantes`);
    }
  });
</script>

