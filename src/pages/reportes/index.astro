---
import MainLayout from "../../layouts/MainLayout.astro";
import ExportButtons from "../../components/reportes/ExportButtons";
import ReportesDashboard from "../../components/reportes/ReportesDashboard";
---
<MainLayout title="Reportes - Sistema de Cotizaciones">
  <div class="space-y-6">
    <header class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <div>
        <h1 class="text-2xl font-semibold text-gray-900">Reportes</h1>
        <p class="text-sm text-gray-500">Dashboard general.</p>
      </div>
      <ExportButtons client:load />
    </header>

    <ReportesDashboard client:load />
  </div>
</MainLayout>
