    <title>{title}</title>
    <style>
      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 12px;
        color: #000;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
