---
// src/pages/cotizaciones/[id]/pdf.astro
export const prerender = false;

import MainLayout from "../../../layouts/MainLayout.astro";
import PDFPreview from "../../../components/cotizaciones/PDFPreview";

const { id } = Astro.params;
if (!id) return Astro.redirect("/cotizaciones");
---

<MainLayout title="PDF Cotización">
  <PDFPreview client:only="react" cotizacionId={id} />
</MainLayout>
